# Default msmtp configuration for the freeunit-drupal image. msmtp is the
# /usr/sbin/sendmail drop-in that PHP's mail() invokes.
#
# This file ships with NO active settings: every line below is commented out,
# and msmtp refuses to send until an SMTP account is configured. Configure mail
# by mounting your own file at /etc/msmtprc, by baking one into a derived
# image, or by uncommenting and editing the template below.
#
# Reference: https://marlam.de/msmtp/msmtp.html
#
# --- Template (uncomment to enable) -----------------------------------------

# Settings shared by every account.
# defaults
# auth on
# tls on
# tls_trust_file /etc/ssl/certs/ca-certificates.crt
# # "-" sends the per-delivery log line to stdout, so attempts surface in
# # `docker logs` instead of a file inside the container.
# logfile -

# The account named "default" is used when sendmail/msmtp is invoked without
# an explicit account selection -- which is how PHP's mail() calls it.
# account default
# host smtp.example.com
# port 587
# # Envelope-from; many providers require it to match the authenticated user.
# from drupal@example.com
# user smtp-user
# # Do NOT put a plaintext `password` here: /etc/msmtprc is world-readable by
# # design (the app user must read it). Read the secret from a mounted file
# # with restrictive permissions instead:
# passwordeval cat /run/secrets/smtp_password
