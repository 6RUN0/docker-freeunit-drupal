root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# Makefiles require real tabs for recipe lines; spaces break the build.
[Makefile]
indent_style = tab

# YAML (CI workflows, compose, dependabot) is conventionally two-space.
[*.{yml,yaml}]
indent_size = 2
